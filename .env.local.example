NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public site URL (Vercel). Used by Capacitor shell default server URL.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Native OAuth redirect — add the same URL in Supabase Auth → URL Configuration
NEXT_PUBLIC_NATIVE_OAUTH_REDIRECT=com.pricewatch.app://auth/callback
SUPABASE_SERVICE_ROLE_KEY=
# For npm run db:catchup / db:apply-011 (Database → Settings → database password; not your login password).
# Direct db.<ref>.supabase.co is IPv6-only; scripts use Session pooler by default (IPv4).
SUPABASE_DB_PASSWORD=
# Optional: paste Session pooler URI from Dashboard → Connect (overrides auto-built URL).
# SUPABASE_DB_URL=
# Optional: if pooler host differs from aws-0-us-east-1.pooler.supabase.com
# SUPABASE_DB_POOLER_HOST=
ZENROWS_API_KEY=
# Decodo Web Scraping API (Flipkart / Meesho / eBay). Use API Playground token as Basic value, or username+password.
DECODO_API_KEY=
# DECODO_API_TOKEN=
# DECODO_USERNAME=
# DECODO_PASSWORD=
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com
CRON_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
